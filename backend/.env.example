PORT=5000

# Google Maps API Key (required)
# Get it from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Solar API Key (for automated roof detection)
# Same as Maps API key, but ensure Solar API is enabled
GOOGLE_SOLAR_API_KEY=your_google_solar_api_key_here

# NREL API Key (free, get from: https://developer.nrel.gov/signup/)
NREL_API_KEY=your_nrel_api_key_here
